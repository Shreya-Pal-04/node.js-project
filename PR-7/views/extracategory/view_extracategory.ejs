<%- include('../header') %>

<div class="page-wrapper">

    <div class="page-breadcrumb">
        <div class="row">
            <div class="col-12 d-flex no-block align-items-center">

                <h4 class="page-title">View All Extra Categories</h4>

                <div class="ml-auto text-right">
                    <nav aria-label="breadcrumb">
                        <ol class="breadcrumb">
                            <li class="breadcrumb-item">
                                <a href="#">Home</a>
                            </li>

                            <li class="breadcrumb-item active">
                                Extra Category
                            </li>
                        </ol>
                    </nav>
                </div>

            </div>
        </div>
    </div>
    <div class="container-fluid">

        <div class="row">
            <div class="col-12">

                <div class="card">

                    <div class="card-body">
                        <h5 class="card-title m-b-0">
                            Extra Category Informations
                        </h5>
                    </div>

                    <!-- Table -->
                    <table class="table">

                        <thead>
                            <tr>
                                <th>#</th>
                                <th>Category Name</th>
                                <th>Subcategory Name</th>
                                <th>Extra Category</th>
                                <th>Actions</th>
                            </tr>
                        </thead>

                        <tbody>
                            <% extracategories.forEach((ex,i)=>{ %>
                                <tr>
                                    <th scope="row">
                                        <%= i + 1 %>
                                    </th>
                                    <td>
                                        <%= ex.categoryId?.category || "No Category" %>
                                    </td>
                                    <td>
                                        <%= ex.subcategoryId?.subcategory || "No Subcategory" %>
                                    </td>
                                    <td>
                                        <%= ex.extraCategory %>
                                    </td>
                                    <td>
                                        <a href="/extracategory/edit_extracategory/<%= ex._id %>"
                                        class="btn btn-warning">
                                        Edit
                                        </a>
                                        <a href="/extracategory/delete_extracategory/<%= ex._id %>"
                                        class="btn btn-danger">
                                        Delete
                                        </a>
                                    </td>
                                </tr>
                            <% }) %>
                        </tbody>
                    </table>
                </div>
            </div>
        </div>
    </div>
</div>

<%- include('../footer') %>