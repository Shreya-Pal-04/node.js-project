<%- include('../header') %>

<div class="page-wrapper">

    <div class="page-breadcrumb">
        <div class="row">
            <div class="col-12 d-flex no-block align-items-center">
                <h4 class="page-title">Add Extra Category</h4>
                <div class="ml-auto text-right">
                    <nav aria-label="breadcrumb">
                        <ol class="breadcrumb">
                            <li class="breadcrumb-item"><a href="#">Home</a></li>
                            <li class="breadcrumb-item active">Extra Category</li>
                        </ol>
                    </nav>
                </div>

            </div>
        </div>
    </div>


    <div class="container-fluid">
        <div class="row">
            <div class="col-md-6">
                <div class="card">
                    <div class="card-body">
                        <h5 class="card-title">Add Extra Category</h5>
                        <form action="/extracategory/add_extracategory" method="post">
                            <div class="form-group">
                                <label>Category</label>
                                <select name="categoryId" id="categoryId" required>
                                <option value="">Select Category</option>
                                <% categories.forEach(cat=>{ %>
                                <option value="<%= cat._id %>">
                                <%= cat.category %>
                                </option>
                                <% }) %>
                                </select>
                            </div>
                            <div class="form-group">
                                <label>Subcategory</label>
                                <select name="subcategoryId" id="subCategoryId" required>
<option value="">Select Subcategory</option>
</select>
                            </div>
                            <div class="form-group">
                                <label>Extra Category Name</label>

                                <input type="text" 
                                name="extraCategory"
                                class="form-control"
                                placeholder="Enter Extra Category">
                            </div>
                            <button type="submit" class="btn btn-primary">
                                Add Extra Category
                            </button>
                        </form>
                    </div>
                </div>
            </div>
        </div>
    </div>
</div>
<%- include('../footer') %>

<script>
let categoryId = document.querySelector('#categoryId');
let subCategoryId = document.querySelector('#subCategoryId');

categoryId.addEventListener('change', () => {

    let category = categoryId.value;

    fetch(`/extracategory/subcategories?categoryId=${category}`)
    .then(res => res.json())
    .then(data => {

        subCategoryId.innerHTML = `<option value="">Select Sub Category</option>`;
        data.forEach(subCat => {
            let option = document.createElement('option');
            option.innerHTML = subCat.subcategory;
            option.value = subCat._id;
            subCategoryId.append(option);
        });
    });
});
</script>