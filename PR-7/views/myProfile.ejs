<%- include('header') %>

<div class="page-wrapper">
  <div class="container-fluid">
    <div class="row justify-content-center">
      
      <div class="col-md-8">
        <div class="card shadow-lg rounded-4">
          
          <div class="card-body text-center bg-light rounded-top">
            
            <% if(user.profileImage && user.profileImage !== "") { %>
              <img src="/<%= user.profileImage %>" 
                   class="rounded-circle shadow" 
                   width="120" 
                   height="120"
                   style="object-fit:cover;">
            <% } else { %>
              <img src="/assets/images/users/1.jpg" 
                   class="rounded-circle shadow" 
                   width="120">
            <% } %>

            <h3 class="mt-3 mb-0">
              <%= user.firstname %> <%= user.lastname %>
            </h3>
            <p class="text-muted"><%= user.email %></p>
          </div>

          <div class="card-body">
            
            <div class="row mb-3">
              <div class="col-md-6">
                <label class="fw-bold">First Name</label>
                <p class="form-control bg-light"><%= user.firstname %></p>
              </div>

              <div class="col-md-6">
                <label class="fw-bold">Last Name</label>
                <p class="form-control bg-light"><%= user.lastname %></p>
              </div>
            </div>

            <div class="row mb-3">
              <div class="col-md-6">
                <label class="fw-bold">Gender</label>
                <p class="form-control bg-light"><%= user.gender %></p>
              </div>

              <div class="col-md-6">
                <label class="fw-bold">Phone Number</label>
                <p class="form-control bg-light"><%= user.mobileNo %></p>
              </div>
            </div>

            <div class="text-end">
              <a href="/admin/editAdmin/<%= user._id %>" class="btn btn-primary px-4">
                Edit Profile
              </a>
              <a href="/changePassword" class="btn btn-warning px-4">
                Change Password
              </a>
            </div>
          </div>

        </div>
      </div>
    </div>
  </div>
</div>

<%- include('footer') %>