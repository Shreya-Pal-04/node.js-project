<%- include('../header') %>

<div class="page-wrapper">
  <div class="container-fluid">
    <div class="row">
      <div class="col-md-8">
        <div class="card">

          <form action="/blog/updateblog/<%= blogData._id %>" 
                method="POST" 
                enctype="multipart/form-data">

            <div class="card-body">
              <h4 class="card-title">Edit Blog</h4>

              <div class="form-group">
                <label>Title</label>
                <input type="text" 
                       name="title" 
                       value="<%= blogData.title %>" 
                       class="form-control" 
                       required>
              </div>

              <div class="form-group">
                <label>Short Description</label>
                <input type="text" 
                       name="shortDes" 
                       value="<%= blogData.shortDes %>" 
                       class="form-control" 
                       required>
              </div>

              <div class="form-group">
                <label>Content</label>
                <textarea name="content" 
                          class="form-control" 
                          rows="5" 
                          required><%= blogData.content %></textarea>
              </div>

<div class="form-group">
  <label>Category</label>

  <select name="category" class="form-control" required>

    <option value="Technology"
      <%= blogData.category === "Technology" ? "selected" : "" %>>
      Technology
    </option>

    <option value="Lifestyle"
      <%= blogData.category === "Lifestyle" ? "selected" : "" %>>
      Lifestyle
    </option>

    <option value="Education / Learning"
      <%= blogData.category === "Education / Learning" ? "selected" : "" %>>
      Education / Learning
    </option>

    <option value="Entertainment"
      <%= blogData.category === "Entertainment" ? "selected" : "" %>>
      Entertainment
    </option>

    <option value="Finance / Business"
      <%= blogData.category === "Finance / Business" ? "selected" : "" %>>
      Finance / Business
    </option>

  </select>
</div>

</select>

              <div class="form-group">
                <label>Change Cover Image</label>
                <input type="file" 
                       name="coverImage" 
                       class="form-control-file">
              </div>

            </div>

            <div class="card-footer">
              <button type="submit" class="btn btn-primary">
                Update Blog
              </button>
            </div>

          </form>

        </div>
      </div>
    </div>
  </div>
</div>

<%- include('../footer') %>