<%- include('../header') %>
<div class="page-wrapper">

    <div class="page-breadcrumb">
        <div class="row">
            <div class="col-12 d-flex no-block align-items-center">
                <h4 class="page-title">View All Products</h4>
                <div class="ml-auto text-right">
                    <nav aria-label="breadcrumb">
                        <ol class="breadcrumb">
                            <li class="breadcrumb-item">
                                <a href="#">Home</a>
                            </li>
                            <li class="breadcrumb-item active">
                                Products
                            </li>
                        </ol>
                    </nav>
                </div>
            </div>
        </div>
    </div>
    <div class="container-fluid">
        <div class="row">
            <div class="col-12">
                <div class="card">
                    <div class="card-body">
                        <h5 class="card-title m-b-0">
                            Product Informations
                        </h5>
                    </div>
                    <table class="table">
                        <thead>
                            <tr>
                                <th>#</th>
                                <th>Product Name</th>
                                <th>Price</th>
                                <th>Quantity</th>
                                <th>Category</th>
                                <th>Subcategory</th>
                                <th>Extra Category</th>
                                <th>Actions</th>
                            </tr>
                        </thead>
                        <tbody>
                            <% products.forEach((pro,i)=>{ %>
                                <tr>
                                    <th scope="row">
                                        <%= i + 1 %>
                                    </th>
                                    <td>
                                        <%= pro.productName %>
                                    </td>
                                    <td>
                                        <%= pro.price %>
                                    </td>
                                    <td>
                                        <%= pro.quantity %>
                                    </td>
                                    <td>
                                        <%= pro.categoryId?.category || "No Category" %>
                                    </td>
                                    <td>
                                        <%= pro.subcategoryId?.subcategory || "No Subcategory" %>
                                    </td>
                                    <td>
                                        <%= pro.extraCategoryId?.extraCategory || "No Extra Category" %>
                                    </td>
                                    <td>
                                        <a href="/product/edit_product/<%= pro._id %>"
                                        class="btn btn-warning">
                                        Edit
                                        </a>
                                        <a href="/product/delete_product/<%= pro._id %>"
                                        class="btn btn-danger">
                                        Delete
                                        </a>
                                    </td>
                                </tr>
                            <% }) %>
                        </tbody>
                    </table>
                </div>
            </div>
        </div>
    </div>
</div>

<%- include('../footer') %>