<%- include('../header') %>

<div class="page-wrapper">

<div class="page-breadcrumb">
<div class="row">
<div class="col-12 d-flex no-block align-items-center">

<h4 class="page-title">Add Product</h4>

<div class="ml-auto text-right">
<nav aria-label="breadcrumb">
<ol class="breadcrumb">
<li class="breadcrumb-item"><a href="#">Home</a></li>
<li class="breadcrumb-item active">Product</li>
</ol>
</nav>
</div>

</div>
</div>
</div>


<div class="container-fluid">

<div class="row">
<div class="col-md-6">

<div class="card">

<div class="card-body">
<h5 class="card-title">Add Product</h5>

<form action="/product/add_product" method="post">



<div class="form-group">
<label>Product Name</label>

<input type="text"
name="productName"
class="form-control"
placeholder="Enter Product Name">
</div>

<div class="form-group">
<label>Price</label>

<input type="number"
name="price"
class="form-control"
placeholder="Enter Price">
</div>


<div class="form-group">
<label>Quantity</label>

<input type="number"
name="quantity"
class="form-control"
placeholder="Enter Quantity">
</div>

<div class="form-group">
<label>Description</label>

<textarea
name="description"
class="form-control"
placeholder="Enter Product Description"></textarea>
</div>

<div class="form-group">
<label>Category</label>

<select name="categoryId" id="categoryId" required>

<option value="">Select Category</option>

<% categories.forEach(cat => { %>

<option value="<%= cat._id %>">
<%= cat.category %>
</option>

<% }) %>

</select>
</div>
<div class="form-group">
<label>Subcategory</label>

<select name="subcategoryId" id="subCategoryId" required>

<option value="">Select Subcategory</option>

</select>

</div>
<div class="form-group">
<label>Extra Category</label>

<select name="extraCategoryId" id="extraCategoryId" required>

<option value="">Select Extra Category</option>

</select>

</div>
<button type="submit" class="btn btn-primary">
Add Product
</button>
</form>
</div>
</div>
</div>
</div>
</div>
</div>

<%- include('../footer') %>
<script>
let categoryId = document.querySelector('#categoryId');
let subCategoryId = document.querySelector('#subCategoryId');
let extraCategoryId = document.querySelector('#extraCategoryId');
categoryId.addEventListener('change', () => {

let category = categoryId.value;

fetch(`/product/subcategory?categoryId=${category}`)
.then(res => res.json())
.then(data => {

subCategoryId.innerHTML = `<option value="">Select Subcategory</option>`;

data.forEach(subCat => {

let option = document.createElement('option');

option.innerHTML = subCat.subcategory;
option.value = subCat._id;

subCategoryId.append(option);
});
});
});
subCategoryId.addEventListener('change', () => {

let subcategory = subCategoryId.value;
tch(`/product/extracategory?subcategoryId=${subcategory}`)
.then(res => res.json())
.then(data => {

extraCategoryId.innerHTML = `<option value="">Select Extra Category</option>`;

data.forEach(extra => {

let option = document.createElement('option');

option.innerHTML = extra.extraCategory;
option.value = extra._id;

extraCategoryId.append(option);
});
});
});
</script>