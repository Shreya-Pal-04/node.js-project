<%- include('../header') %>

<div class="page-wrapper">

    <div class="page-breadcrumb">
        <div class="row">
            <div class="col-12 d-flex no-block align-items-center">
                <h4 class="page-title">View All Subcategories</h4>

                <div class="ml-auto text-right">
                    <nav aria-label="breadcrumb">
                        <ol class="breadcrumb">
                            <li class="breadcrumb-item"><a href="#">Home</a></li>
                            <li class="breadcrumb-item active">Subcategories</li>
                        </ol>
                    </nav>
                </div>

            </div>
        </div>
    </div>
    <div class="container-fluid">
        <div class="row">
            <div class="col-12">

                <div class="card">

                    <div class="card-body">
                        <h5 class="card-title m-b-0">Subcategory Informations</h5>
                    </div>

                    <table class="table">

                        <thead>
                            <tr>
                                <th>#</th>
                                <th>Category Name</th>
                                <th>Image</th>
                                <th>Sub Category Name</th>
                                <th>Actions</th>
                            </tr>
                        </thead>

                        <tbody>

                            <% subcategories.forEach((cat, i) => { %>
                                <tr>
                                    <th scope="row"><%= i + 1 %></th>
                                    <td>
                                        <%= cat.categoryId?.category || "No Category" %>
                                    </td>
                                    <td>

                                        <% if(cat.categoryId?.categoryImage){ %>

                                            <img src="<%= cat.categoryId.categoryImage %>" width="70">

                                        <% } else { %>

                                            No Image

                                        <% } %>

                                    </td>
                                    <td>
                                        <%= cat.subcategory %>
                                    </td>
                                    <td>

                                        <a href="/subcategory/edit_subcategory/<%= cat._id %>" 
                                        class="btn btn-warning">
                                        Edit
                                        </a>


                                        <a href="/subcategory/delete_subcategory/<%= cat._id %>" 
                                        class="btn btn-danger"
                                        onclick="return confirm('Are you sure you want to delete this subcategory?')">
                                        Delete
                                        </a>
                                    </td>
                                </tr>
                            <% }) %>
                        </tbody>
                    </table>
                </div>
            </div>
        </div>
    </div>
</div>

<%- include('../footer') %>